{
  "name": "@ubm-hyogo/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "NODE_ENV=production next build",
    "build:cloudflare": "NODE_ENV=production opennextjs-cloudflare build && node ../../scripts/patch-open-next-worker.mjs",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "dev": "next dev",
    "lint": "tsc -p tsconfig.json --noEmit && eslint 'src/**/*.{ts,tsx}'",
    "preview:cloudflare": "pnpm build:cloudflare && opennextjs-cloudflare preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --root=../.. --config=vitest.config.ts apps/web",
    "test:coverage": "vitest run --passWithNoTests --root=../.. --config=vitest.config.ts --coverage --coverage.reportsDirectory=apps/web/coverage --coverage.include=\"apps/web/src/**/*.{ts,tsx}\" apps/web",
    "test:e2e": "playwright test",
    "test:e2e:list": "playwright test --list"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "1.19.4",
    "@sentry/cloudflare": "^10.51.0",
    "@sentry/nextjs": "^10.51.0",
    "@ubm-hyogo/shared": "workspace:*",
    "next": "16.2.4",
    "next-auth": "5.0.0-beta.30",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/postcss": "~4.0.0",
    "@types/node": "24.10.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/parser": "^8.59.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "eslint": "^10.3.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "~4.0.0",
    "typescript": "6.0.3",
    "wrangler": "4.85.0"
  }
}
