{
  "name": "@ubm-hyogo/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json --noEmit",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --root=../.. --config=vitest.config.ts apps/api",
    "test:coverage:unit": "vitest run --passWithNoTests --root=../.. --config=vitest.config.ts --coverage --coverage.reportsDirectory=apps/api/coverage/unit --coverage.include=\"apps/api/src/**/*.{ts,tsx}\" --maxWorkers=1 --minWorkers=1 apps/api",
    "test:coverage:d1": "vitest run --passWithNoTests --root=../.. --config=vitest.d1.config.ts --coverage --coverage.reportsDirectory=apps/api/coverage/d1 --coverage.include=\"apps/api/src/**/*.{ts,tsx}\" apps/api",
    "test:coverage": "pnpm run test:coverage:unit && pnpm run test:coverage:d1 && cd ../.. && node scripts/coverage-merge.mjs --inputs=\"apps/api/coverage/unit/coverage-final.json,apps/api/coverage/d1/coverage-final.json\" --output=\"apps/api/coverage\""
  },
  "dependencies": {
    "@ubm-hyogo/integrations": "workspace:*",
    "@ubm-hyogo/contracts": "workspace:*",
    "@ubm-hyogo/integrations-google": "workspace:*",
    "@ubm-hyogo/shared": "workspace:*",
    "hono": "4.12.18"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260426.1",
    "miniflare": "4.20260424.0",
    "typescript": "6.0.3",
    "vitest": "^2.1.9",
    "wrangler": "4.85.0"
  }
}
