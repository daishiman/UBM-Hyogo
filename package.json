{
  "name": "ubm-hyogo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "volta": {
    "node": "24.15.0",
    "pnpm": "10.33.2"
  },
  "engines": {
    "node": "24.x",
    "pnpm": "10.x"
  },
  "scripts": {
    "with-env": "bash scripts/with-env.sh",
    "build": "bash scripts/with-env.sh pnpm -r build",
    "dev:web": "bash scripts/with-env.sh pnpm --filter @ubm-hyogo/web dev",
    "dev:api": "bash scripts/with-env.sh pnpm --filter @ubm-hyogo/api dev",
    "lint": "node scripts/lint-boundaries.mjs && pnpm run lint:deps && node scripts/lint-stablekey-literal.mjs && pnpm -r lint",
    "lint:deps": "rg --files apps packages -g '*.ts' -g '*.tsx' | xargs pnpm dlx dependency-cruiser --config .dependency-cruiser.cjs",
    "lint:stablekey": "node scripts/lint-stablekey-literal.mjs",
    "lint:stablekey:strict": "node scripts/lint-stablekey-literal.mjs --strict",
    "typecheck": "pnpm -r typecheck",
    "test": "bash scripts/with-env.sh vitest run",
    "test:scripts": "bash scripts/d1/run-tests.sh",
    "test:coverage": "bash scripts/with-env.sh vitest run --coverage",
    "coverage:guard": "bash scripts/coverage-guard.sh",
    "env:check": "bash scripts/with-env.sh node -e \"['GOOGLE_CLIENT_ID','GOOGLE_CLIENT_SECRET','GOOGLE_SHEET_ID','GOOGLE_SERVICE_ACCOUNT_JSON','CLOUDFLARE_API_TOKEN','CLOUDFLARE_ACCOUNT_ID','AUTH_SECRET'].forEach(k=>console.log(k+': '+(process.env[k]?'OK':'MISSING')))\"",
    "env:export": "op inject -i .env -o .env.local",
    "prepare": "lefthook install",
    "indexes:rebuild": "node .claude/skills/aiworkflow-requirements/scripts/generate-index.js",
    "sync:check": "git fetch --quiet origin main dev 2>/dev/null; bash scripts/hooks/stale-worktree-notice.sh fetch",
    "skill:logs:render": "tsx scripts/skill-logs-render.ts",
    "skill:logs:append": "tsx scripts/skill-logs-append.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "@cloudflare/workers-types": "4.20260426.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^4.0.0",
    "jsdom": "^25.0.0",
    "lefthook": "^1.7.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "typescript": "6.0.3",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "wrangler": "4.85.0"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
