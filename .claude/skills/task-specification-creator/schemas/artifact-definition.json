{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "artifact-definition.json",
  "title": "Artifact Definition",
  "description": "成果物レジストリ（artifacts.json）のスキーマ",
  "type": "object",
  "required": ["phases"],
  "anyOf": [
    {
      "required": ["feature", "created", "lastUpdated"]
    },
    {
      "required": ["task_name", "created_at"]
    }
  ],
  "properties": {
    "feature": {
      "type": "string",
      "description": "機能名（ケバブケース）",
      "pattern": "^[a-z0-9-]+$"
    },
    "task_name": {
      "type": "string",
      "description": "legacy workflow 名"
    },
    "task_path": {
      "type": "string",
      "description": "legacy workflow path"
    },
    "wave": {
      "type": "number",
      "description": "legacy wave number"
    },
    "execution_mode": {
      "type": "string",
      "description": "legacy execution mode"
    },
    "depends_on": {
      "type": "array",
      "items": { "type": "string" },
      "description": "legacy upstream list"
    },
    "blocks": {
      "type": "array",
      "items": { "type": "string" },
      "description": "legacy downstream blockers"
    },
    "created": {
      "type": "string",
      "format": "date-time",
      "description": "作成日時（ISO 8601）"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "legacy 作成日時（ISO 8601）"
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time",
      "description": "最終更新日時（ISO 8601）"
    },
    "status": {
      "type": "string",
      "enum": ["spec_created", "in_progress", "runtime_pending", "completed", "on_hold", "blocked"],
      "description": "ワークフロー全体のステータス。canonical 3-state vocabulary（spec_created / runtime_pending / completed）と legacy（in_progress / on_hold / blocked）を許容。詳細は references/workflow-state-vocabulary.md を参照。"
    },
    "phases": {
      "anyOf": [
        {
          "type": "object",
          "description": "Phase別の成果物と状態",
          "patternProperties": {
            "^[0-9]+$": {
              "type": "object",
              "required": ["status"],
              "properties": {
                "status": {
                  "type": "string",
                  "enum": ["pending", "spec_created", "in_progress", "runtime_pending", "completed", "skipped", "blocked"],
                  "description": "Phaseステータス。canonical 3-state vocabulary（spec_created / runtime_pending / completed）と legacy（pending / in_progress / skipped / blocked）を許容。runtime CI 実行前は completed を付与せず runtime_pending を採用する。詳細は references/workflow-state-vocabulary.md / phase-12-spec.md §Phase ステータス語彙 3 値定義 を参照。"
                },
                "startedAt": {
                  "type": "string",
                  "format": "date-time",
                  "description": "開始日時"
                },
                "completedAt": {
                  "type": "string",
                  "format": "date-time",
                  "description": "完了日時"
                },
                "artifacts": {
                  "type": "array",
                  "description": "成果物一覧",
                  "items": {
                    "oneOf": [
                      {
                        "type": "string",
                        "description": "legacy/simple artifact path"
                      },
                      {
                        "type": "object",
                        "required": ["type", "path"],
                        "properties": {
                          "type": {
                            "type": "string",
                            "enum": ["document", "code", "test", "config"],
                            "description": "成果物タイプ"
                          },
                          "path": {
                            "type": "string",
                            "description": "成果物パス"
                          },
                          "description": {
                            "type": "string",
                            "description": "成果物説明"
                          }
                        }
                      }
                    ]
                  }
                },
                "notes": {
                  "type": "string",
                  "description": "備考・引き継ぎ事項"
                }
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "array",
          "description": "legacy Phase別の成果物と状態",
          "items": {
            "type": "object",
            "required": ["phase", "name", "file", "status"],
            "properties": {
              "phase": {
                "type": "number",
                "description": "Phase番号"
              },
              "name": {
                "type": "string",
                "description": "Phase名称"
              },
              "file": {
                "type": "string",
                "description": "Phase仕様ファイル"
              },
              "status": {
                "type": "string",
                "enum": ["pending", "spec_created", "in_progress", "runtime_pending", "completed", "skipped", "blocked"],
                "description": "Phaseステータス。canonical 3-state vocabulary（spec_created / runtime_pending / completed）と legacy（pending / in_progress / skipped / blocked）を許容。"
              },
              "outputs": {
                "type": "array",
                "description": "成果物一覧",
                "items": { "type": "string" }
              },
              "depends_on_phases": {
                "type": "array",
                "items": { "type": "number" },
                "description": "依存Phase"
              },
              "user_approval_required": {
                "type": "boolean",
                "description": "ユーザー承認要否"
              }
            }
          }
        }
      ]
    },
    "dependencies": {
      "type": "object",
      "description": "Phase間の依存関係マップ",
      "patternProperties": {
        "^[0-9]+$": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "追加メタデータ",
      "properties": {
        "taskType": {
          "type": "string",
          "description": "推奨は短い canonical type。既存 workflow の hyphen/underscore 形式も許容する。",
          "anyOf": [
            {
              "enum": ["feat", "fix", "refactor", "docs", "test", "chore", "improvement"]
            },
            {
              "pattern": "^[a-z][a-z0-9_-]*$"
            }
          ]
        },
        "estimatedPhases": {
          "type": "integer",
          "description": "予定Phase数"
        },
        "actualPhases": {
          "type": "integer",
          "description": "実行Phase数"
        },
        "workflow_state": {
          "type": "string",
          "description": "canonical workflow state（spec_created / CONTRACT_READY_IMPLEMENTATION_PENDING / implemented_local_evidence_captured / PASS_BOUNDARY_SYNCED_RUNTIME_PENDING / runtime_pending / verified_current_no_code_change_pending_pr / completed）。references/workflow-state-vocabulary.md 参照"
        },
        "governance_mutation_user_gate": {
          "type": "boolean",
          "description": "governance mutation（gh api -X PUT / wrangler deploy / d1 migrations apply / gh secret set 等の不可逆 mutation）に user 明示承認 gate を要する場合 true。references/non-visual-irreversible-task-rules.md §0 参照"
        },
        "mutation_commands": {
          "type": "array",
          "items": { "type": "string" },
          "description": "governance_mutation_user_gate=true 時に実行予定の mutation コマンドを literal 一覧で列挙する"
        },
        "read_only_evidence_allowed_pre_gate": {
          "type": "array",
          "items": { "type": "string" },
          "description": "user 承認前に AI 実行可能な read-only evidence 取得コマンド一覧"
        },
        "user_approval_marker": {
          "type": "string",
          "description": "user 明示承認 evidence の物理保存先（例: outputs/phase-13/user-approval-<task-id>-<timestamp>.md）"
        },
        "actual_read_only_evidence_files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Phase 11/13 で取得済みの read-only evidence ファイル群（branch protection GET / migrations list / fresh GET JSON 等）。governance / NON_VISUAL タスクでは mutation evidence と分離して台帳化する"
        },
        "actual_mutation_evidence_files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "user 承認後に実行した mutation の evidence ファイル群（gh api -X PUT の after JSON / wrangler deploy log 等）。user_approval_marker と対で管理する"
        }
      }
    },
    "external_services": {
      "type": "array",
      "items": { "type": "string" },
      "description": "legacy 外部サービス一覧"
    },
    "secrets_introduced": {
      "type": "array",
      "items": { "type": "string" },
      "description": "legacy 新規 secret 一覧"
    },
    "infra_artifacts": {
      "type": "array",
      "items": { "type": "string" },
      "description": "legacy infra artifacts"
    },
    "doc_references": {
      "type": "array",
      "items": { "type": "string" },
      "description": "legacy documentation references"
    }
  },
  "additionalProperties": false
}
