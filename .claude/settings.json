  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'REPO=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0; STAMP=\"$REPO/.git/.wt-health-last-check\"; NOW=$(date +%s); LAST=$(cat \"$STAMP\" 2>/dev/null || echo 0); [ $((NOW - LAST)) -lt 600 ] && exit 0; echo \"$NOW\" > \"$STAMP\"; git fetch origin main --quiet 2>/dev/null; bash \"$REPO/scripts/wt-health-check.sh\" --silent 2>/dev/null || true'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'REPO=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0; bash \"$REPO/.claude/hooks/check-unassigned-tasks.sh\" 2>&1 || true'"
          }
        ]
      }
    ]
  },
  "outputStyle": "日本語。thinkingモードも含めて、すべての処理・思考プロセスも含めて日本語を使うこと。",
  "skipDangerousModePermissionPrompt": false,
  "$schema_version": "2.0",
  "$description": "Claude Code settings - 公式仕様準拠の最適化版",
  "mcpServers": {
    "desktop-commander": {
      "command": "npx",
      "args": [
        "@wonderwhy-er/desktop-commander@latest"
      ]
    },
    "arxiv-mcp-server": {
      "command": "uv",
      "args": [
        "tool",
        "run",
        "arxiv-mcp-server",
        "--storage-path",
        "~/Documents/ArxivPapers"
      ]
    },
    "pdf-agent": {
      "command": "/Users/dm/.nvm/versions/node/v20.19.0/bin/node",
      "args": [
        "/Users/dm/Documents/pdf-agent-mcp/server/index.js"
      ]
    },
    "mcp-pdf-reader": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/Safe-Swiss-Cloud-AG/mcp_pdf_reader@main",
        "mcp_pdf_reader"
      ]
    }
  }
}
