%% 08a test architecture — test 種別 × endpoint × repository
flowchart TB
  subgraph SRC[apps/api/src]
    direction TB
    R_PUB[routes/public/*<br/>stats, members, member-profile, form-preview]
    R_ME[routes/me/*<br/>profile, services]
    R_ADM[routes/admin/*<br/>dashboard, members, member-status, member-notes,<br/>member-delete, tags-queue, schema, meetings,<br/>attendance, sync, sync-schema, responses-sync]
    R_AUTH[routes/auth/*<br/>magic-link, magic-link/verify, resolve-session,<br/>session-resolve, gate-state]
    M[middleware<br/>admin-gate, session-guard, require-admin,<br/>internal-auth, rate-limit-*]
    REPO[repository/*<br/>22 modules: members, responses, responseSections,<br/>responseFields, fieldVisibility, identities,<br/>memberTags, tagDefinitions, tagQueue,<br/>schemaVersions, schemaQuestions, schemaDiffQueue,<br/>meetings, attendance, magicTokens,<br/>adminUsers, adminNotes, auditLog,<br/>publicMembers, dashboard, status, syncJobs]
    SHARED[(packages/shared<br/>brand types: responseId,<br/>memberId, meetingSessionId)]
  end

  subgraph TEST[apps/api/test + src/**/__tests__]
    direction TB
    H[helpers<br/>app.ts, auth.ts, seed.ts, reset.ts]
    F[fixtures<br/>members, responses, meetings, tags,<br/>admin-users, magic-tokens, audit-log]
    MSW[mocks<br/>forms-api.handlers.ts<br/>server.ts]
    FD[fakeD1<br/>repository/_shared/__fakes__/fakeD1.ts]
  end

  subgraph SPECS[specs by 種別]
    direction TB
    C[contract spec<br/>32 件 *.contract.spec.ts<br/>zod parse + status code]
    U[unit spec<br/>22 件 repository/__tests__/*.test.ts]
    A[authz spec<br/>9 マトリクス *.authz.test.ts]
    T[type test<br/>brand.type.test-d.ts<br/>responseId !== memberId]
    L[lint/boundary spec<br/>tests/lint/import-boundary.test.ts<br/>apps/web → D1 禁止]
    INV[invariant spec<br/>#1 #2 #5 #6 #7 #11<br/>各 1 ID]
  end

  R_PUB --> C
  R_ME --> C
  R_ADM --> C
  R_AUTH --> C
  REPO --> U
  M --> A
  R_PUB & R_ME & R_ADM --> A
  SHARED --> T
  H --> C & U & A
  F --> C & U & A
  MSW --> C
  FD --> U & C & A
  C & U & A & T & L & INV --> CI[GitHub Actions<br/>.github/workflows/api-tests.yml<br/>pnpm --filter @ubm-hyogo/api test:coverage]

  classDef invar fill:#fef3c7,stroke:#a16207
  class INV invar
