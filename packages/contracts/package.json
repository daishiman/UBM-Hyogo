{
  "name": "@ubm-hyogo/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.mjs",
    "./src": "./src/index.mjs"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --root=../.. --config=vitest.config.ts packages/contracts",
    "test:coverage": "vitest run --passWithNoTests --root=../.. --config=vitest.config.ts --coverage --coverage.reportsDirectory=packages/contracts/coverage --coverage.include=\"packages/contracts/src/**/*.{ts,tsx,mjs}\" packages/contracts"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
